APP_NAME="Automatismos Marpel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=marpel
DB_USERNAME=marpel
DB_PASSWORD=marpel_secret

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=240

FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS=admin@automatismosmarpel.local
MAIL_FROM_NAME="${APP_NAME}"

MARPEL_API_TOKEN=change-me
MARPEL_NOTION_API_TOKEN=change-me
RUN_MIGRATIONS=false

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI="${APP_URL}/admin/google-calendar/callback"
GOOGLE_CALENDAR_ID=primary
